# This repository intentionally tracks the current adaptive-keypoint project only.
# Everything else in D:\kp is treated as local source material or legacy work.
/*
!/.gitignore
!/.gitattributes
!/AGENTS.md
!/README.md
!/adaptive_keypoint_survey_report.base.docx
!/adaptive_keypoint_discovery_reboot/

# Secrets and machine-local state
**/.env
**/.env.*
!**/.env.example
**/.idea/
**/.vscode/
**/__pycache__/
**/*.py[cod]
**/.ipynb_checkpoints/
**/Thumbs.db
**/.DS_Store

# Upstream sources, downloaded checkpoints, training products, and quarantine
/adaptive_keypoint_discovery_reboot/_do_not_package/
/adaptive_keypoint_discovery_reboot/experiment/third_party/
/adaptive_keypoint_discovery_reboot/experiment/training_outputs/
/adaptive_keypoint_discovery_reboot/experiment/evaluation_outputs/threshold_sweep_val/
/adaptive_keypoint_discovery_reboot/experiment/evaluation_outputs/topology_reuse_val_v2/
/adaptive_keypoint_discovery_reboot/experiment/pseudo_labels_g1prime_v4_fullplant/overlays/
**/wandb/
**/runs/
**/checkpoints/
**/*.pt
**/*.pth
**/*.ckpt
**/*.onnx
**/*.pack
**/*.idx
**/*.do_not_use
**/*.zip

# Superseded or reconstructable image collections.
# The compact, reviewed V3 dataset remains tracked for reproducibility.
/adaptive_keypoint_discovery_reboot/experiment/data_g0/
/adaptive_keypoint_discovery_reboot/experiment/stage_source_extracted/
/adaptive_keypoint_discovery_reboot/experiment/data_stage_clean_v1/
/adaptive_keypoint_discovery_reboot/experiment/data_stage_clean_v2/
/adaptive_keypoint_discovery_reboot/experiment/data_stage_clean_v3_candidate/
/adaptive_keypoint_discovery_reboot/experiment/data_stage_clean_v3_incomplete_timeout/
/adaptive_keypoint_discovery_reboot/experiment/data_stage_clean_v3_pre_component_cleanup/

# Local V4 construction trials and superseded candidate gates.
/adaptive_keypoint_discovery_reboot/experiment/_scratch_v4_*/
/adaptive_keypoint_discovery_reboot/experiment/data_stage_clean_v4_candidate_pre_*/
/adaptive_keypoint_discovery_reboot/experiment/data_source_reaudit/inspect*.jpg
/adaptive_keypoint_discovery_reboot/experiment/data_source_reaudit/scanner_group_audit.jpg
/adaptive_keypoint_discovery_reboot/experiment/data_stage_clean_v4_fullplant_smoke*/
/adaptive_keypoint_discovery_reboot/experiment/data_stage_clean_v4_fullplant_candidate_failed_*/
/adaptive_keypoint_discovery_reboot/experiment/data_stage_clean_v4_candidate_shoot_only_*/
